# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/remotechef

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d
JWT_ADMIN_SECRET=your_admin_jwt_secret_here

# Flutterwave
FLW_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxxxx-X
FLW_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxxxx-X
FLW_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxx
FLW_WEBHOOK_HASH=your_flutterwave_webhook_hash

# Frontend URL (for CORS + redirect)
FRONTEND_URL=http://localhost:8080

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=remotechef@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=RemoteChef <remotechef@gmail.com>

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
